# OneLap到多平台数据同步工具配置文件（示例）

[app]
name = OneLap到多平台数据同步工具
version = 1.2.13
log_level = INFO
headless_mode = false
debug_mode = false

[onelap]
username = 13800138000
password = your_password_here

[xoss]
username = 13800138000
password = your_password_here
enable_sync = false

[giant]
username = 13800138000
password = your_password_here
enable_sync = false

[igpsport]
username = 13800138000
password = your_password_here
enable_sync = false

[garmin]
username = 13800138000
password = your_password_here
enable_sync = false
# Garmin 每批最多上传文件数；0 表示使用 [sync] max_files_per_batch
max_upload_files = 0

[strava]
enable_sync = false
client_id =
client_secret =
access_token =
refresh_token =
expires_at = 0
redirect_port = 8765
athlete_id =
athlete_name =
# OneLap FIT 使用 GCJ-02 坐标系，Strava 需要 WGS84；启用后上传前自动转换
gcj02_to_wgs84 = true

[sync]
storage_dir = ./downloads
supported_formats = .fit,.gpx,.tcx
max_file_size_mb = 50
max_files_per_batch = 5
# OneLap 是否强制全量下载 (true=全量下载并忽略各平台基准, false=按基准增量下载)
onelap_full_sync = false

[igpsport_to_onelap]
enable = false
mode = auto
strategy = time_based

